|rtl|datapath:U1_DATAPATH
rsr => ~NO_FANOUT~
clk => registrador_pc:U1_PC.clk
clk => registrador_instruc:U3_IR.clk
ld_pc => registrador_pc:U1_PC.ld_pc
clr_pc => registrador_pc:U1_PC.clr_pc
