clr_instruc => registrador_instruc:U3_IR.clr_instruc
opcode[0] <= registrador_instruc:U3_IR.instruc_out[0]
opcode[1] <= registrador_instruc:U3_IR.instruc_out[1]


|rtl|datapath:U1_DATAPATH|registrador_pc:U1_PC
clk => pc_out[0]~reg0.CLK
clk => pc_out[1]~reg0.CLK
clr_pc => pc_out.OUTPUTSELECT
clr_pc => pc_out.OUTPUTSELECT
ld_pc => pc_out.OUTPUTSELECT
ld_pc => pc_out.OUTPUTSELECT
pc_in[0] => pc_out.DATAB
pc_in[1] => pc_out.DATAB
pc_out[0] <= pc_out[0]~reg0.DB_MAX_OUTPUT_PORT_TYPE
pc_out[1] <= pc_out[1]~reg0.DB_MAX_OUTPUT_PORT_TYPE


|rtl|datapath:U1_DATAPATH|somador_pc:U2_SOMADOR
pc_in[0] => Add0.IN4
pc_in[0] => Equal0.IN1
pc_in[1] => Add0.IN3
pc_in[1] => Equal0.IN0
pc_out[0] <= pc_out.DB_MAX_OUTPUT_PORT_TYPE
pc_out[1] <= pc_out.DB_MAX_OUTPUT_PORT_TYPE


|rtl|datapath:U1_DATAPATH|registrador_instruc:U3_IR
