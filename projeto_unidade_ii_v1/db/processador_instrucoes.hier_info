|rtl|datapath:U1_DATAPATH|memoria_instrucao:U4_MEMORIA
endereco[0] => instrucao[0].DATAIN
endereco[0] => instrucao[2].DATAIN
endereco[1] => instrucao[1].DATAIN
endereco[1] => instrucao[3].DATAIN
