instruc_in[5] => instruc_out.DATAB
instruc_in[6] => instruc_out.DATAB
instruc_in[7] => instruc_out.DATAB
instruc_out[0] <= instruc_out[0]~reg0.DB_MAX_OUTPUT_PORT_TYPE
